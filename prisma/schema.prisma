generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  ENVIADO_AL_NEGOCIO
  ACEPTADO
  REPARTIDOR_EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum UserRole {
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(ADMIN)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

model Order {
  id               String      @id @default(cuid())
  publicId         String      @unique
  adminToken       String      @unique

  cliente          String
  telefono         String?
  detalle          String
  direccion        String
  total            Int
  idChat           String?

  status           OrderStatus @default(ENVIADO_AL_NEGOCIO)
  estimatedMinutes Int?
  deliveryFee      Int?

  acceptedAt       DateTime?
  pickupAt         DateTime?
  deliveredAt      DateTime?
  cancelledAt      DateTime?
  cancelReason     String?

  internalNotes    String?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([idChat, total, createdAt])
  @@index([status, createdAt])
}
