# Base de datos (Railway Postgres)
DATABASE_URL="postgresql://user:pass@host:5432/db"

# URL pública de la app (sin trailing slash). Usada para construir los links
# que devuelve POST /api/pedidos (tracking + admin).
APP_BASE_URL="http://localhost:3000"

# Secret para firmar las cookies de sesión del panel admin.
# Generar con: openssl rand -base64 48
JWT_SECRET=""

# Secret que protege POST /api/admin/users (crea nuevos admins).
# Solo el dueño/dev lo conoce. Generar con: openssl rand -base64 32
ADMIN_BOOTSTRAP_SECRET=""

# Email del dueño que recibe notificación cuando entra un pedido nuevo.
# Opcional: si no se setea, notifyNewOrder() loguea warning y sigue.
ADMIN_EMAIL=""
